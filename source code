#define BLYNK_TEMPLATE_ID "ISI TEMPLATE ID"
#define BLYNK_TEMPLATE_NAME "ISI TEMPLATE NAMA"
#define BLYNK_AUTH_TOKEN "ISI AUTH TOKEN BLYNK"

#define BLYNK_PRINT Serial

#include <ESP8266WiFi.h>
#include <BlynkSimpleEsp8266.h>
#include <Servo.h>

char ssid[] = "ISI NAMA WIFI";
char pass[] = "ISI PASSWORD WIFI";

// Pin komponen ESP8266
#define LDR_PIN A0
#define SERVO_PIN D4

// Ambang batas cahaya
#define AMBANG_CAHAYA 500

// Posisi servo
#define SERVO_TUTUP 0
#define SERVO_BUKA 90

Servo servo;
BlynkTimer timer;

int nilaiLDR;
int sudutServo;

void bacaSensorLDR() {
  nilaiLDR = analogRead(LDR_PIN);

  // Jika nilai LDR lebih kecil dari ambang, dianggap gelap
  if (nilaiLDR < AMBANG_CAHAYA) {
    sudutServo = SERVO_TUTUP;
    Serial.print("Kondisi: Gelap");
  } 
  else {
    sudutServo = SERVO_BUKA;
    Serial.print("Kondisi: Terang");
  }

  servo.write(sudutServo);

  // Kirim data ke Blynk
  Blynk.virtualWrite(V0, nilaiLDR);
  Blynk.virtualWrite(V1, sudutServo);

  Serial.print(" | Nilai LDR: ");
  Serial.print(nilaiLDR);
  Serial.print(" | Sudut Servo: ");
  Serial.println(sudutServo);
}

void setup() {
  Serial.begin(115200);

  servo.attach(SERVO_PIN);
  servo.write(SERVO_TUTUP);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  timer.setInterval(1000L, bacaSensorLDR);
}

void loop() {
  Blynk.run();
  timer.run();
}
